# ═══════════════════════════════════════════════════════════
# ШАБЛОН ПЕРЕМЕННЫХ ОКРУЖЕНИЯ
# ═══════════════════════════════════════════════════════════
# Этот файл МОЖНО коммитить в Git
# Скопируй в .env.development или .env.production и заполни

# ───────────────────────────────────────────────────────────
# СЕРВЕР
# ───────────────────────────────────────────────────────────
PORT=1488
NODE_ENV=development

# ───────────────────────────────────────────────────────────
# URL САЙТА
# ───────────────────────────────────────────────────────────
SITE_URL=https://lorikowka.github.io/

# ───────────────────────────────────────────────────────────
# ЮKASSA (ТЕСТОВЫЙ РЕЖИМ)
# ───────────────────────────────────────────────────────────
# Получить в личном кабинете yookassa.ru
YOOKASSA_SHOP_ID=283451
YOOKASSA_SECRET_KEY=test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Режим: test или production
PAYMENT_MODE=test

# ───────────────────────────────────────────────────────────
# БЕЗОПАСНОСТЬ
# ───────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=dev_secret_key_change_in_production_12345678901234567890123456789012

# Ключ для проверки webhook (будет предоставлен ЮKassa)
YOOKASSA_WEBHOOK_SECRET=webhook_test_secret

# ───────────────────────────────────────────────────────────
# RATE LIMITING
# ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ───────────────────────────────────────────────────────────
# ЛОГИРОВАНИЕ
# ───────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ───────────────────────────────────────────────────────────
# CORS (для production)
# ───────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://psixolog-site.ru
