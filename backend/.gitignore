# ═══════════════════════════════════════════════════════════
# .gitignore — Безопасность
# ═══════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# СЕКРЕТНЫЕ ФАЙЛЫ (НИКОГДА НЕ КОММИТИТЬ!)
# ───────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.production.local
*.env

# ───────────────────────────────────────────────────────────
# ЗАВИСИМОСТИ
# ───────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ───────────────────────────────────────────────────────────
# ЛОГИ
# ───────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ───────────────────────────────────────────────────────────
# ОС
# ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ───────────────────────────────────────────────────────────
# IDE
# ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ───────────────────────────────────────────────────────────
# ВРЕМЕННЫЕ ФАЙЛЫ
# ───────────────────────────────────────────────────────────
tmp/
temp/
.cache/

# ───────────────────────────────────────────────────────────
# Vercel
# ───────────────────────────────────────────────────────────
.vercel/

# ───────────────────────────────────────────────────────────
# КЛЮЧИ И СЕРТИФИКАТЫ
# ───────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
keys/
